{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u4e2a\u4eba\u7f51\u7ad9","text":""},{"location":"#_2","title":"\u5173\u4e8e\u8fd9\u4e2a\u7a7a\u95f4","text":"<p>\u8fd9\u91cc\u8bb0\u5f55\u7740\u6211\u7684\u5b66\u4e60\u3001\u601d\u8003\u4e0e\u4e8b\u60c5\u3002\u6211\u76ee\u524d\u628a\u5185\u5bb9\u5f52\u5230\u4e09\u4e2a\u6838\u5fc3\u533a\u57df\uff1a</p> \u533a\u57df \u5185\u5bb9 \u7279\u70b9 \u77e5\u8bc6 \u539f\u5b50\u5316\u7b14\u8bb0\u3001\u6982\u5ff5\u6574\u7406 \u8fd9\u662f\u4e00\u4e2a\u4e0d\u65ad\u751f\u957f\u3001\u6f14\u5316\u7684\u4e2a\u4eba\u77e5\u8bc6\u533a\u57df \u6587\u7ae0 \u65b9\u6cd5\u3001\u5fc3\u7406\u4e0e\u7ecf\u9a8c\u53cd\u601d \u601d\u8003\uff0c\u68b3\u7406 \u9879\u76ee \u6211\u76ee\u524d\u5728\u505a\u3001\u505a\u8fc7\u7684\u6709\u610f\u601d\u7684\u4e8b\u60c5 \u5305\u542b\u4e3b\u9898\u7814\u7a76\u4e0e\u83dc\u5355\u7b49\u751f\u6d3b\u5b9e\u9a8c <p>\u87ba\u65cb\u4e0a\u5347</p> <p>\u77e5\u8bc6\u5e2e\u52a9\u6211\u6c89\u6dc0\uff0c\u6587\u7ae0\u5e2e\u52a9\u6211\u7ec4\u7ec7\uff0c\u9879\u76ee\u5219\u9a71\u52a8\u505a\u4e8b\u7684\u8fc7\u7a0b\u3002</p>"},{"location":"#_3","title":"\u4e3a\u4ec0\u4e48\u9009\u62e9\u7f51\u7ad9\u4f5c\u4e3a\u4e2a\u4eba\u88c5\u7f6e\uff1f","text":"<ul> <li>\u6240\u6709\u6743\uff1a\u4e0d\u4f9d\u6258\u4efb\u4f55\u5e73\u53f0\uff0c\u8fd9\u662f\u72ec\u5c5e\u4e8e\u81ea\u5df1\u7684\u4e00\u7247\u5929\u5730\uff1b</li> <li>\u5b9e\u9a8c\u6027\uff1a\u5728\u8fd9\u91cc\u8bd5\u9a8c\u4e00\u79cd\u7406\u60f3\u7684\u4e2a\u4eba\u751f\u6d3b\u7ec4\u7ec7\u5f62\u5f0f\uff1b</li> <li>\u8d1f\u8d23\u4efb\uff1a\u5c06\u81ea\u5df1\u7684\u751f\u6d3b\u7f16\u7ec7\u5728\u793e\u4f1a\u7f51\u7edc\u4e2d\uff0c\u8ba9\u81ea\u5df1\u66f4\u8d1f\u8d23\u4efb\u3002</li> </ul> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e742\u6708</p>"},{"location":"articles/","title":"\u6587\u7ae0","text":"<p>\u8fd9\u91cc\u653e\u7684\u662f\u9002\u5408\u5b8c\u6574\u9605\u8bfb\u7684\u5185\u5bb9\u3002\u76f8\u6bd4\u77e5\u8bc6\u9875\uff0c\u8fd9\u91cc\u7684\u5199\u4f5c\u66f4\u5f3a\u8c03\u5c55\u5f00\u8bba\u8ff0\u3001\u6574\u7406\u7ecf\u9a8c\uff0c\u4ee5\u53ca\u5f62\u6210\u76f8\u5bf9\u5b8c\u6574\u7684\u89c2\u70b9\u3002</p> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>"},{"location":"atomic-notes/","title":"\u539f\u5b50\u5316\u7b14\u8bb0","text":"<p>\u4e00\u79cd\u5c06\u77e5\u8bc6\u62c6\u89e3\u4e3a\u6700\u5c0f\u53ef\u7ba1\u7406\u5355\u5143\u7684\u7b14\u8bb0\u65b9\u6cd5\u3002</p>","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#_2","title":"\u6838\u5fc3\u7406\u5ff5","text":"","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#_3","title":"\u4e3a\u4ec0\u4e48\u9700\u8981\u539f\u5b50\u5316\uff1f","text":"\u95ee\u9898 \u4f20\u7edf\u7b14\u8bb0 \u539f\u5b50\u5316\u7b14\u8bb0 \u6574\u5408 \u4fe1\u606f\u6563\u843d\u5728\u4e0d\u540c\u8f7d\u4f53 \u6309\u6982\u5ff5\u805a\u5408\u591a\u6e90\u4fe1\u606f \u8fed\u4ee3 \u7b14\u8bb0\u5199\u5b8c\u5373\u5f03 \u6301\u7eed\u66f4\u65b0\u3001\u6df1\u5316 \u53cd\u9988 \u96be\u4ee5\u611f\u77e5\u8fdb\u6b65 \u6bcf\u5b66\u4e00\u4e2a\u6982\u5ff5\u5c31\u6709\u83b7\u5f97\u611f <p>\u6838\u5fc3\u9690\u55bb</p> <ul> <li>\u77e5\u8bc6\u5982\u6c34\uff0c\u8f7d\u4f53\u5982\u676f\u2014\u2014\u76ee\u7684\u662f\u559d\u6c34\uff0c\u800c\u975e\u6536\u96c6\u676f\u5b50</li> <li>\u624b\u6307\u6307\u5411\u6708\u4eae\uff0c\u800c\u975e\u6307\u5411\u6708\u4eae\u7684\u624b\u6307</li> </ul>","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#_4","title":"\u4e09\u5927\u539f\u5219","text":"","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#1","title":"1. \u4e00\u6761\u7b14\u8bb0\u53ea\u505a\u4e00\u4ef6\u4e8b","text":"<p>\u6bcf\u6761\u7b14\u8bb0\u53ea\u8bb0\u5f55\u4e00\u4e2a\u610f\u4e49\u7c07\uff08\u539f\u5b50\uff09\uff1a</p> <ul> <li>\u4e00\u4e2a\u6982\u5ff5</li> <li>\u4e00\u4e2a\u4e8b\u5b9e</li> <li>\u4e00\u4e2a\u7ecf\u9a8c</li> <li>\u4e00\u4e2a\u60f3\u6cd5</li> <li>\u4e00\u4e2a\u95ee\u9898</li> </ul> <p>\u793a\u4f8b</p> <p>\u5728\u4e00\u672c\u4e66\u91cc\u770b\u5230\u300c\u4e00\u4e2a\u73b0\u8c61\u300d\u6216\u300c\u4e00\u79cd\u884c\u4e3a\u300d\uff0c\u5c31\u4ee5\u5b83\u4e3a\u6807\u9898\u5efa\u7acb\u7b14\u8bb0\u3002</p> <p>\u52a8\u6001\u62c6\u5206\uff1a\u5185\u5bb9\u591a\u4e86\u518d\u8003\u8651\u62c6\u5206\uff0c\u4e0d\u5fc5\u4e00\u5f00\u59cb\u5c31\u8fc7\u5ea6\u7ec6\u5206\u3002</p>","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#2","title":"2. \u4e00\u6761\u7b14\u8bb0\u505a\u597d\u4e00\u4ef6\u4e8b","text":"<p>\u597d\u7b14\u8bb0\u7684\u7279\u5f81</p> <ul> <li>\u8bf4\u81ea\u5df1\u7684\u8bdd\uff1a\u7528\u81ea\u5df1\u7684\u8bdd\u8bed\u4f53\u7cfb\u8868\u8fbe</li> <li>\u6709\u4f8b\u5b50\uff1a\u642d\u914d\u5177\u4f53\u7684\u4f8b\u5b50\u548c\u7c7b\u6bd4</li> <li>\u6709\u94fe\u63a5\uff1a\u4e0e\u5176\u4ed6\u77e5\u8bc6\u70b9\u5efa\u7acb\u8054\u7cfb</li> <li>\u5e38\u9752\uff1a\u4e0d\u65ad\u8fed\u4ee3\u3001\u4fee\u6539\u3001\u751f\u957f</li> </ul>","tags":["\u5b66\u4e60"]},{"location":"atomic-notes/#3","title":"3. \u6a21\u677f\u5316\u4e0e\u6807\u51c6\u5316","text":"<p>\u91c7\u7528\u4e00\u81f4\u7684\u7b14\u8bb0\u7ed3\u6784\uff0c\u4fbf\u4e8e\u68c0\u7d22\u548c\u6269\u5c55\uff1a</p> <pre><code># \u6982\u5ff5\u540d\u79f0\n\n## \u5b9a\u4e49\n[\u7528\u81ea\u5df1\u7684\u8bdd\u89e3\u91ca]\n\n## \u4f8b\u5b50\n[\u5177\u4f53\u6848\u4f8b]\n\n## \u5173\u8054\n[\u76f8\u5173\u6982\u5ff51] | [\u76f8\u5173\u6982\u5ff52]\n\n## \u6765\u6e90\n[\u53c2\u8003\u8d44\u6599]\n</code></pre>","tags":["\u5b66\u4e60"]},{"location":"cognitive-dissonance/","title":"\u8ba4\u77e5\u5931\u8c03","text":"<p>\u8ba4\u77e5\u5931\u8c03\uff0c\u6307\u7684\u662f\u4e00\u4e2a\u4eba\u540c\u65f6\u62e5\u6709\u4e92\u76f8\u51b2\u7a81\u7684\u60f3\u6cd5\u3001\u884c\u4e3a\u6216\u81ea\u6211\u89e3\u91ca\uff0c\u7531\u6b64\u4ea7\u751f\u5fc3\u7406\u4e0a\u7684\u4e0d\u9002\u611f\u3002</p> <p>\u8fd9\u79cd\u4e0d\u9002\u901a\u5e38\u4e0d\u4f1a\u76f4\u63a5\u8868\u73b0\u4e3a\u201c\u6211\u903b\u8f91\u77db\u76fe\u4e86\u201d\uff0c\u800c\u66f4\u5e38\u8868\u73b0\u4e3a\uff1a</p> <ul> <li>\u5fc3\u91cc\u522b\u626d</li> <li>\u60f3\u66ff\u81ea\u5df1\u627e\u7406\u7531</li> <li>\u60f3\u5feb\u901f\u8bc1\u660e\u81ea\u5df1\u6ca1\u9519</li> <li>\u660e\u660e\u77e5\u9053\u6709\u95ee\u9898\uff0c\u5374\u4e0d\u613f\u610f\u6b63\u9762\u627f\u8ba4</li> </ul>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_2","title":"\u4f8b\u5b50","text":"<p>\u6bd4\u5982\uff0c\u4e00\u4e2a\u4eba\u76f8\u4fe1\u81ea\u5df1\u5f88\u91cd\u89c6\u5065\u5eb7\uff0c\u4f46\u4ed6\u53c8\u957f\u671f\u71ac\u591c\u3001\u4e45\u5750\u3001\u4e0d\u8fd0\u52a8\u3002</p> <p>\u8fd9\u65f6\uff0c\u8111\u4e2d\u5c31\u4f1a\u51fa\u73b0\u51b2\u7a81\uff1a</p> <ul> <li>\u89c2\u5ff5\uff1a\u5065\u5eb7\u5f88\u91cd\u8981</li> <li>\u884c\u4e3a\uff1a\u6211\u6b63\u5728\u505a\u4f24\u5bb3\u5065\u5eb7\u7684\u4e8b</li> </ul> <p>\u8fd9\u79cd\u51b2\u7a81\u5c31\u662f\u8ba4\u77e5\u5931\u8c03\u3002</p> <p>\u4e3a\u4e86\u51cf\u8f7b\u4e0d\u9002\uff0c\u4eba\u5e38\u5e38\u4f1a\u81ea\u52a8\u751f\u6210\u4e00\u4e9b\u89e3\u91ca\uff1a</p> <ul> <li>\u6700\u8fd1\u5de5\u4f5c\u592a\u5fd9\uff0c\u7279\u6b8a\u65f6\u671f\u6ca1\u529e\u6cd5</li> <li>\u6211\u867d\u7136\u6ca1\u8fd0\u52a8\uff0c\u4f46\u6211\u8111\u529b\u6d88\u8017\u5f88\u5927</li> <li>\u4ee5\u540e\u8865\u56de\u6765\u5c31\u884c</li> </ul> <p>\u8fd9\u4e9b\u89e3\u91ca\u4e0d\u4e00\u5b9a\u5b8c\u5168\u9519\u8bef\uff0c\u4f46\u5b83\u4eec\u7ecf\u5e38\u627f\u62c5\u4e00\u4e2a\u989d\u5916\u529f\u80fd\uff1a\u5e2e\u52a9\u4eba\u7ef4\u6301\u201c\u6211\u8fd8\u662f\u4e00\u4e2a\u8bb2\u9053\u7406\u7684\u4eba\u201d\u7684\u81ea\u6211\u5f62\u8c61\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_3","title":"\u8ba4\u77e5\u5931\u8c03\u4e3a\u4ec0\u4e48\u91cd\u8981","text":"<p>\u56e0\u4e3a\u5f88\u591a\u62d6\u5ef6\u3001\u81ea\u6211\u6b3a\u9a97\u548c\u4f4e\u6548\u5faa\u73af\uff0c\u5e76\u4e0d\u662f\u5355\u7eaf\u56e0\u4e3a\u61d2\uff0c\u800c\u662f\u56e0\u4e3a\u4eba\u4f1a\u672c\u80fd\u5730\u56de\u907f\u81ea\u6211\u51b2\u7a81\u3002</p> <p>\u4e00\u65e6\u67d0\u4e2a\u4e8b\u5b9e\u5a01\u80c1\u5230\u201c\u6211\u662f\u4e00\u4e2a\u600e\u6837\u7684\u4eba\u201d\u8fd9\u4e2a\u53d9\u4e8b\uff0c\u5927\u8111\u5c31\u503e\u5411\u4e8e\u4f18\u5148\u4fdd\u62a4\u53d9\u4e8b\uff0c\u800c\u4e0d\u662f\u4f18\u5148\u4fee\u6b63\u884c\u4e3a\u3002</p> <p>\u6240\u4ee5\uff0c\u8ba4\u77e5\u5931\u8c03\u5e76\u4e0d\u53ea\u662f\u4e00\u4e2a\u5fc3\u7406\u5b66\u6982\u5ff5\uff0c\u5b83\u5176\u5b9e\u548c\u5f88\u591a\u65e5\u5e38\u95ee\u9898\u76f4\u63a5\u76f8\u5173\uff1a</p> <ul> <li>\u4e3a\u4ec0\u4e48\u4eba\u4f1a\u7ed9\u62d6\u5ef6\u627e\u501f\u53e3</li> <li>\u4e3a\u4ec0\u4e48\u4eba\u660e\u660e\u77e5\u9053\u8be5\u505a\u4ec0\u4e48\uff0c\u5374\u8fdf\u8fdf\u4e0d\u505a</li> <li>\u4e3a\u4ec0\u4e48\u4eba\u4f1a\u8d8a\u89e3\u91ca\u8d8a\u8fdc\u79bb\u4e8b\u5b9e</li> </ul>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_4","title":"\u5728\u5b66\u4e60\u548c\u5de5\u4f5c\u4e2d\u7684\u8868\u73b0","text":"<p>\u8ba4\u77e5\u5931\u8c03\u5728\u5b66\u4e60\u548c\u5de5\u4f5c\u91cc\u4e5f\u5f88\u5e38\u89c1\u3002</p> <p>\u4f8b\u5982\uff1a</p> <ul> <li>\u6211\u8ba4\u4e3a\u81ea\u5df1\u662f\u4e00\u4e2a\u8ba4\u771f\u5b66\u4e60\u7684\u4eba\uff0c\u4f46\u6211\u4eca\u5929\u51e0\u4e4e\u6ca1\u6709\u5b66\u4e60</li> <li>\u6211\u8ba4\u4e3a\u81ea\u5df1\u5728\u63a8\u8fdb\u9879\u76ee\uff0c\u4f46\u6211\u4e00\u6574\u5929\u90fd\u5728\u6574\u7406\u5de5\u5177\u548c\u8d44\u6599</li> <li>\u6211\u8ba4\u4e3a\u81ea\u5df1\u8ffd\u6c42\u771f\u5b9e\uff0c\u4f46\u6211\u5728\u56de\u907f\u4e00\u4e2a\u5df2\u7ecf\u5f88\u660e\u663e\u7684\u95ee\u9898</li> </ul> <p>\u5982\u679c\u4e0d\u8bc6\u522b\u8fd9\u79cd\u5931\u8c03\uff0c\u4eba\u5c31\u4f1a\u4e0d\u65ad\u7528\u201c\u89e3\u91ca\u201d\u4ee3\u66ff\u201c\u4fee\u6b63\u201d\u3002\u65f6\u95f4\u4e00\u4e45\uff0c\u95ee\u9898\u4e0d\u4ec5\u4e0d\u4f1a\u6d88\u5931\uff0c\u53cd\u800c\u4f1a\u79ef\u7d2f\u6210\u66f4\u5f3a\u7684\u5185\u8017\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_5","title":"\u600e\u4e48\u66f4\u597d\u5730\u9762\u5bf9\u5b83","text":"","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_6","title":"\u5148\u627f\u8ba4\u51b2\u7a81\u5b58\u5728","text":"<p>\u5f88\u591a\u65f6\u5019\uff0c\u95ee\u9898\u4e0d\u662f\u51b2\u7a81\u672c\u8eab\uff0c\u800c\u662f\u6211\u4eec\u4e0d\u80af\u627f\u8ba4\u51b2\u7a81\u5b58\u5728\u3002</p> <p>\u4e00\u53e5\u66f4\u6709\u7528\u7684\u8bdd\u901a\u5e38\u4e0d\u662f\u201c\u6211\u6ca1\u95ee\u9898\u201d\uff0c\u800c\u662f\uff1a</p> <p>\u6211\u73b0\u5728\u7684\u60f3\u6cd5\u548c\u884c\u4e3a\u786e\u5b9e\u4e0d\u4e00\u81f4\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_7","title":"\u5c11\u505a\u81ea\u6211\u8fa9\u62a4\uff0c\u591a\u770b\u5177\u4f53\u884c\u4e3a","text":"<p>\u4e0d\u8981\u6025\u7740\u8bc1\u660e\u81ea\u5df1\u662f\u5bf9\u7684\uff0c\u5148\u770b\u4e8b\u5b9e\uff1a</p> <ul> <li>\u6211\u4eca\u5929\u5b9e\u9645\u505a\u4e86\u4ec0\u4e48\uff1f</li> <li>\u6211\u6b63\u5728\u56de\u907f\u4ec0\u4e48\uff1f</li> <li>\u6211\u662f\u5728\u89e3\u51b3\u95ee\u9898\uff0c\u8fd8\u662f\u5728\u66ff\u81ea\u5df1\u89e3\u91ca\uff1f</li> </ul>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_8","title":"\u7528\u5c0f\u884c\u52a8\u4fee\u590d\u4e00\u81f4\u6027","text":"<p>\u8ba4\u77e5\u5931\u8c03\u4e0d\u4e00\u5b9a\u8981\u9760\u4e00\u6b21\u5927\u6539\u53d8\u6765\u89e3\u51b3\u3002\u5f88\u591a\u65f6\u5019\uff0c\u4e00\u4e2a\u8db3\u591f\u5c0f\u3001\u4f46\u771f\u5b9e\u7684\u884c\u52a8\uff0c\u5c31\u80fd\u5f00\u59cb\u4fee\u590d\u5185\u5728\u4e00\u81f4\u6027\u3002</p> <p>\u6bd4\u5982\uff1a</p> <ul> <li>\u5199 100 \u5b57\uff0c\u800c\u4e0d\u662f\u60f3\u7740\u201c\u8981\u5199\u4e00\u7bc7\u5b8c\u6574\u6587\u7ae0\u201d</li> <li>\u8fd0\u52a8 10 \u5206\u949f\uff0c\u800c\u4e0d\u662f\u7b49\u201c\u5b8c\u6574\u5065\u8eab\u8ba1\u5212\u201d</li> <li>\u5148\u505a\u6700\u5173\u952e\u7684\u4e00\u6b65\uff0c\u800c\u4e0d\u662f\u7ee7\u7eed\u89e3\u91ca\u4e3a\u4ec0\u4e48\u8fd8\u6ca1\u5f00\u59cb</li> </ul>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"cognitive-dissonance/#_9","title":"\u788e\u788e\u5ff5","text":"<ol> <li>\u4e0d\u81ea\u6b3a\u662f\u6700\u96be\u7684\u4e8b\uff1b</li> <li>\u8bbe\u8ba1\u81ea\u5df1\u7684\u81ea\u6211\u4fee\u6b63\u673a\u5236\u5f88\u91cd\u8981\uff1b</li> </ol> <p>\u5f53\u5185\u5fc3\u4e0d\u8212\u670d\u65f6\uff0c\u5148\u522b\u6025\u7740\u81ea\u8bc1\u6e05\u767d\uff0c\u4e5f\u8bb8\u771f\u6b63\u9700\u8981\u7684\u4e0d\u662f\u89e3\u91ca\uff0c\u800c\u662f\u4fee\u6b63\u3002</p> <p>\u6700\u540e\u66f4\u65b0\uff1a2026 \u5e74 3 \u6708</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"knowledge/","title":"\u77e5\u8bc6","text":"<p>\u8fd9\u91cc\u653e\u7684\u662f\u6211\u4f1a\u53cd\u590d\u56de\u770b\u7684\u77e5\u8bc6\u5185\u5bb9\uff1a\u6982\u5ff5\u62c6\u89e3\u3001\u65b9\u6cd5\u8bba\uff0c\u4ee5\u53ca\u5e2e\u52a9\u6211\u628a\u95ee\u9898\u60f3\u6e05\u695a\u7684\u7b14\u8bb0\u3002</p> <ul> <li> <p> \u539f\u5b50\u5316\u7b14\u8bb0</p> <p>\u628a\u77e5\u8bc6\u62c6\u6210\u53ef\u94fe\u63a5\u3001\u53ef\u590d\u7528\u3001\u53ef\u8fed\u4ee3\u7684\u6700\u5c0f\u5355\u5143\u3002</p> <p> \u8fdb\u5165\u9875\u9762</p> </li> <li> <p> \u5de5\u5177\u7656</p> <p>\u53cd\u601d\u5de5\u5177\u6536\u96c6\u51b2\u52a8\uff0c\u63d0\u9192\u81ea\u5df1\u628a\u6ce8\u610f\u529b\u8fd8\u7ed9\u771f\u6b63\u7684\u5de5\u4f5c\u3002</p> <p> \u8fdb\u5165\u9875\u9762</p> </li> <li> <p> \u8ba4\u77e5\u5931\u8c03</p> <p>\u8bb0\u5f55\u90a3\u4e9b\u884c\u52a8\u548c\u60f3\u6cd5\u4e92\u76f8\u62c9\u626f\u7684\u65f6\u523b\uff0c\u4ee5\u53ca\u6211\u5982\u4f55\u8bc6\u522b\u5b83\u4eec\u3002</p> <p> \u8fdb\u5165\u9875\u9762</p> </li> </ul> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>"},{"location":"menu/","title":"\u83dc\u5355","text":"<p>\u8fd9\u91cc\u662f\u9879\u76ee\u6a21\u5757\u91cc\u7684\u4e00\u4e2a\u751f\u6d3b\u5b9e\u9a8c\u5b50\u9875\u3002\u6211\u628a\u90a3\u4e9b\u7b80\u5355\u3001\u7a33\u5b9a\u3001\u9002\u5408\u65e5\u5e38\u590d\u505a\u7684\u83dc\u8c31\u505a\u6210\u5e73\u94fa\u5361\u7247\uff0c\u65b9\u4fbf\u76f4\u63a5\u6311\u9009\u3002</p> <ul> <li>\u897f\u7ea2\u67ff\u9e21\u86cb\u6c64</li> </ul> <p>\u4e00\u9053\u6750\u6599\u7b80\u5355\u3001\u51fa\u9519\u7387\u4f4e\u3001\u9002\u5408\u5de5\u4f5c\u65e5\u665a\u9910\u7684\u5bb6\u5e38\u6c64\u3002</p> <p> \u67e5\u770b\u505a\u6cd5</p> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>"},{"location":"projects/","title":"\u9879\u76ee","text":"<p>\u8fd9\u91cc\u653e\u7684\u662f\u6211\u6b63\u5728\u63a8\u8fdb\u3001\u6301\u7eed\u6253\u78e8\uff0c\u6216\u503c\u5f97\u957f\u671f\u4fdd\u7559\u7684\u9879\u76ee\u3002\u5b83\u65e2\u5305\u62ec\u4e3b\u9898\u7814\u7a76\uff0c\u4e5f\u5305\u62ec\u50cf\u83dc\u5355\u8fd9\u6837\u7684\u751f\u6d3b\u5b9e\u9a8c\u6a21\u5757\u3002</p> <ul> <li> <p> \u83dc\u5355</p> <p>\u628a\u53ef\u91cd\u590d\u590d\u73b0\u7684\u5bb6\u5e38\u505a\u6cd5\u6574\u7406\u6210\u56fe\u7247\u5361\u7247\uff0c\u4f5c\u4e3a\u9879\u76ee\u6a21\u5757\u91cc\u7684\u751f\u6d3b\u5b9e\u9a8c\u5b50\u533a\u3002</p> <p> \u6253\u5f00\u83dc\u5355</p> </li> </ul> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>"},{"location":"tags/","title":"\u6807\u7b7e","text":"<p>\u8fd9\u91cc\u6c47\u603b\u672c\u7ad9\u4f7f\u7528\u8fc7\u7684\u6807\u7b7e\uff0c\u65b9\u4fbf\u6309\u4e3b\u9898\u5feb\u901f\u6d4f\u89c8\u3002</p>"},{"location":"tags/#tag:\u5b66\u4e60","title":"\u5b66\u4e60","text":"<ul> <li>            \u539f\u5b50\u5316\u7b14\u8bb0          </li> </ul>"},{"location":"tags/#tag:\u5bb6\u5e38\u83dc","title":"\u5bb6\u5e38\u83dc","text":"<ul> <li>            \u897f\u7ea2\u67ff\u9e21\u86cb\u6c64          </li> </ul>"},{"location":"tags/#tag:\u81ea\u6211\u514b\u670d","title":"\u81ea\u6211\u514b\u670d","text":"<ul> <li>            \u5de5\u5177\u7656          </li> <li>            \u8ba4\u77e5\u5931\u8c03          </li> </ul>"},{"location":"tomato-egg-soup/","title":"\u897f\u7ea2\u67ff\u9e21\u86cb\u6c64","text":"<p>\u897f\u7ea2\u67ff\u9e21\u86cb\u6c64\u7684\u4f18\u70b9\u662f\u7b80\u5355\u3001\u7a33\u5b9a\uff0c\u800c\u4e14\u975e\u5e38\u9002\u5408\u5f53\u4f5c\u4e00\u987f\u996d\u91cc\u7684\u70ed\u6c64\u642d\u914d\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#_2","title":"\u98df\u6750","text":"<ul> <li>\u897f\u7ea2\u67ff 2 \u4e2a</li> <li>\u9e21\u86cb 2 \u4e2a</li> <li>\u5c0f\u8471 1 \u6839</li> <li>\u76d0\u9002\u91cf</li> <li>\u767d\u80e1\u6912\u7c89\u5c11\u8bb8</li> <li>\u9999\u6cb9\u51e0\u6ef4</li> <li>\u98df\u7528\u6cb9 1 \u5c0f\u52fa</li> <li>\u6e05\u6c34\u7ea6 700-800 ml</li> </ul> <p>\u5982\u679c\u60f3\u8ba9\u6c64\u66f4\u6d53\u4e00\u70b9\uff0c\u4e5f\u53ef\u4ee5\u51c6\u5907\u5c11\u91cf\u6c34\u6dc0\u7c89\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#_3","title":"\u505a\u6cd5","text":"","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#1","title":"1. \u5904\u7406\u98df\u6750","text":"<ul> <li>\u897f\u7ea2\u67ff\u6d17\u51c0\uff0c\u5207\u5757</li> <li>\u9e21\u86cb\u6253\u6563</li> <li>\u5c0f\u8471\u5207\u8471\u82b1</li> </ul>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#2","title":"2. \u7092\u51fa\u5e95\u5473","text":"<p>\u9505\u4e2d\u653e\u5c11\u91cf\u6cb9\uff0c\u5148\u4e0b\u897f\u7ea2\u67ff\u7ffb\u7092 1-2 \u5206\u949f\uff0c\u7092\u5230\u8fb9\u7f18\u53d8\u8f6f\u3001\u5f00\u59cb\u51fa\u6c41\u3002</p> <p>\u5982\u679c\u559c\u6b22\u6c64\u66f4\u9c9c\u66f4\u6d53\uff0c\u8fd9\u4e00\u6b65\u53ef\u4ee5\u591a\u7092\u4e00\u4f1a\u513f\uff0c\u8ba9\u897f\u7ea2\u67ff\u7684\u5473\u9053\u66f4\u5145\u5206\u91ca\u653e\u51fa\u6765\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#3","title":"3. \u716e\u6c64","text":"<p>\u52a0\u5165\u6e05\u6c34\uff0c\u5927\u706b\u716e\u5f00\u540e\u8f6c\u4e2d\u706b\u518d\u716e 2-3 \u5206\u949f\u3002</p> <p>\u6b64\u65f6\u6839\u636e\u53e3\u5473\u52a0\u5165\u9002\u91cf\u76d0\u548c\u5c11\u8bb8\u767d\u80e1\u6912\u7c89\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#4","title":"4. \u6dcb\u5165\u86cb\u6db2","text":"<p>\u628a\u706b\u8c03\u5230\u4e2d\u5c0f\u706b\uff0c\u4e00\u8fb9\u7f13\u6162\u5012\u5165\u86cb\u6db2\uff0c\u4e00\u8fb9\u7528\u7b77\u5b50\u6216\u52fa\u5b50\u8f7b\u8f7b\u63a8\u52a8\u6c64\u9762\uff0c\u8ba9\u86cb\u82b1\u81ea\u7136\u6563\u5f00\u3002</p> <p>\u5982\u679c\u60f3\u8ba9\u6c64\u7565\u5fae\u7a20\u4e00\u70b9\uff0c\u53ef\u4ee5\u5148\u6dcb\u4e00\u70b9\u5f88\u8584\u7684\u6c34\u6dc0\u7c89\uff0c\u518d\u4e0b\u86cb\u6db2\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#5","title":"5. \u51fa\u9505","text":"<p>\u6700\u540e\u6492\u4e0a\u8471\u82b1\uff0c\u6ef4\u51e0\u6ef4\u9999\u6cb9\uff0c\u5c31\u53ef\u4ee5\u5173\u706b\u76db\u51fa\u3002</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#_4","title":"\u4e00\u4e2a\u7a33\u5b9a\u7248\u672c\u7684\u5c0f\u63d0\u793a","text":"<ul> <li>\u60f3\u66f4\u9c9c\uff1a\u897f\u7ea2\u67ff\u8981\u5148\u7092\u8f6f</li> <li>\u60f3\u66f4\u597d\u770b\uff1a\u86cb\u6db2\u4e0d\u8981\u4e00\u6b21\u731b\u5012</li> <li>\u60f3\u66f4\u987a\u53e3\uff1a\u767d\u80e1\u6912\u7c89\u53ea\u653e\u4e00\u70b9\u70b9\u5373\u53ef</li> <li>\u60f3\u66f4\u6709\u9971\u8179\u611f\uff1a\u53ef\u4ee5\u642d\u914d\u7c73\u996d\u3001\u9762\u6761\u6216\u8005\u9992\u5934</li> </ul>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tomato-egg-soup/#_5","title":"\u9002\u5408\u4ec0\u4e48\u65f6\u5019\u505a","text":"<p>\u8fd9\u9053\u6c64\u5f88\u9002\u5408\uff1a</p> <ul> <li>\u5de5\u4f5c\u65e5\u665a\u996d</li> <li>\u98df\u6b32\u4e00\u822c\u7684\u65f6\u5019</li> <li>\u60f3\u505a\u70b9\u70ed\u4e4e\u7684\u3001\u4f46\u53c8\u4e0d\u60f3\u590d\u6742\u64cd\u4f5c\u7684\u65f6\u5019</li> </ul> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>","tags":["\u5bb6\u5e38\u83dc"]},{"location":"tool-obsession/","title":"\u5de5\u5177\u7656","text":"<p>\u5de5\u5177\u7656\uff0c\u6307\u7684\u662f\u628a\u5927\u91cf\u65f6\u95f4\u82b1\u5728\u6311\u5de5\u5177\u3001\u6362\u5de5\u5177\u3001\u7814\u7a76\u5de5\u5177\u548c\u4f18\u5316\u5de5\u5177\u4e0a\uff0c\u6700\u540e\u5374\u6ca1\u6709\u771f\u6b63\u63a8\u8fdb\u4e8b\u60c5\u672c\u8eab\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_2","title":"\u5b83\u4e3a\u4ec0\u4e48\u5e38\u89c1","text":"<p>\u5f88\u591a\u56f0\u96be\u770b\u8d77\u6765\u50cf\u662f\u201c\u5de5\u5177\u4e0d\u591f\u597d\u201d\uff0c\u4f46\u5b9e\u9645\u4e0a\uff0c\u771f\u6b63\u8ba9\u4eba\u75db\u82e6\u7684\u5f80\u5f80\u662f\uff1a</p> <ul> <li>\u62d6\u5ef6</li> <li>\u754f\u96be</li> <li>\u601d\u8003\u672c\u8eab\u7684\u6d88\u8017</li> <li>\u5bf9\u7ed3\u679c\u4e0d\u786e\u5b9a\u7684\u7126\u8651</li> </ul> <p>\u4e8e\u662f\uff0c\u4eba\u5f88\u5bb9\u6613\u628a\u6ce8\u610f\u529b\u4ece\u201c\u505a\u4e8b\u201d\u8f6c\u79fb\u5230\u201c\u914d\u88c5\u5907\u201d\u4e0a\u3002\u7814\u7a76\u5de5\u5177\u4f1a\u5e26\u6765\u4e00\u79cd\u865a\u5047\u7684\u8fdb\u5c55\u611f\uff0c\u56e0\u4e3a\u5b83\u770b\u8d77\u6765\u5f88\u52aa\u529b\uff0c\u4e5f\u5f88\u5bb9\u6613\u83b7\u5f97\u5373\u65f6\u53cd\u9988\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_3","title":"\u5de5\u5177\u7656\u7684\u5178\u578b\u8868\u73b0","text":"","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#1","title":"1. \u603b\u60f3\u627e\u5230\u5b8c\u7f8e\u5de5\u5177","text":"<p>\u5e38\u89c1\u60f3\u6cd5\u5305\u62ec\uff1a</p> <ul> <li>\u6211\u662f\u4e0d\u662f\u8fd8\u6ca1\u627e\u5230\u6700\u9002\u5408\u81ea\u5df1\u7684 AI \u5de5\u5177\uff1f</li> <li>\u6211\u662f\u4e0d\u662f\u8fd8\u9700\u8981\u4e00\u4e2a\u66f4\u597d\u7684\u7b14\u8bb0\u8f6f\u4ef6\uff1f</li> <li>\u8fd9\u4e2a\u6d41\u7a0b\u8fd8\u80fd\u4e0d\u80fd\u7ee7\u7eed\u4f18\u5316\uff1f</li> </ul> <p>\u8fd9\u4e9b\u95ee\u9898\u672c\u8eab\u5e76\u4e0d\u574f\uff0c\u95ee\u9898\u5728\u4e8e\uff1a\u5f53\u5b83\u4eec\u53cd\u590d\u51fa\u73b0\uff0c\u5374\u59cb\u7ec8\u6ca1\u6709\u8f6c\u5316\u4e3a\u5b9e\u9645\u884c\u52a8\u65f6\uff0c\u5de5\u5177\u5c31\u4ece\u624b\u6bb5\u53d8\u6210\u4e86\u9003\u907f\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#2","title":"2. \u628a\u7814\u7a76\u5de5\u5177\u8bef\u8ba4\u4e3a\u7814\u7a76\u539f\u7406","text":"<p>\u6709\u4e9b\u4eba\u82b1\u4e86\u5f88\u591a\u65f6\u95f4\u7814\u7a76\u8f6f\u4ef6\u600e\u4e48\u5206\u7c7b\u3001\u6807\u7b7e\u600e\u4e48\u8bbe\u8ba1\u3001\u9875\u9762\u600e\u4e48\u6392\u7248\uff0c\u5374\u5f88\u5c11\u53bb\u78b0\u771f\u6b63\u56f0\u96be\u7684\u90e8\u5206\uff1a</p> <ul> <li>\u8bfb\u61c2\u4e00\u672c\u4e66</li> <li>\u5199\u5b8c\u4e00\u7bc7\u6587\u7ae0</li> <li>\u63a8\u8fdb\u4e00\u4e2a\u9879\u76ee</li> <li>\u9762\u5bf9\u4e00\u4ef6\u81ea\u5df1\u4e0d\u60f3\u505a\u4f46\u5fc5\u987b\u505a\u7684\u4e8b</li> </ul> <p>\u8fd9\u65f6\u5019\uff0c\u5de5\u5177\u4f18\u5316\u770b\u8d77\u6765\u50cf\u662f\u7cbe\u8fdb\uff0c\u5b9e\u9645\u4e0a\u5374\u662f\u5728\u7ed5\u5f00\u4e8b\u60c5\u672c\u8eab\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#3","title":"3. \u6d88\u8d39\u5de5\u5177\uff0c\u800c\u4e0d\u662f\u4f7f\u7528\u5de5\u5177","text":"<p>\u201c\u5dee\u751f\u6587\u5177\u591a\u201d\u8fd9\u53e5\u8bdd\u867d\u7136\u7c97\u7cd9\uff0c\u4f46\u70b9\u51fa\u4e86\u4e00\u4e2a\u73b0\u8c61\uff1a</p> <p>\u4e00\u4e2a\u4eba\u5982\u679c\u6301\u7eed\u6d88\u8d39\u65b0\u5de5\u5177\uff0c\u5374\u59cb\u7ec8\u6ca1\u6709\u5efa\u7acb\u8d77\u7a33\u5b9a\u7684\u5de5\u4f5c\u56de\u8def\uff0c\u90a3\u4e48\u4ed6\u4ecd\u7136\u505c\u7559\u5728\u6d88\u8d39\u8005\u7684\u4f4d\u7f6e\uff0c\u800c\u4e0d\u662f\u751f\u4ea7\u8005\u7684\u4f4d\u7f6e\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_4","title":"\u4e00\u4e2a\u66f4\u5065\u5eb7\u7684\u539f\u5219","text":"<p>\u5de5\u5177\u591f\u7528\u5c31\u884c\u3002\u5200\u80fd\u780d\u65ad\u6728\u5934\uff0c\u5c31\u8be5\u53bb\u5288\u67f4\uff0c\u800c\u4e0d\u662f\u4e00\u76f4\u78e8\u5200\u3002</p> <p>\u771f\u6b63\u6210\u719f\u7684\u5de5\u5177\u89c2\uff0c\u4e0d\u662f\u8ffd\u6c42\u201c\u6700\u5f3a\u914d\u7f6e\u201d\uff0c\u800c\u662f\u8ffd\u6c42\u201c\u5c3d\u5feb\u8fdb\u5165\u5de5\u4f5c\u72b6\u6001\u201d\u3002</p> <p>\u53ef\u4ee5\u7528\u4e0b\u9762\u4e09\u4e2a\u6807\u51c6\u6765\u5224\u65ad\u4e00\u4e2a\u5de5\u5177\u662f\u4e0d\u662f\u5df2\u7ecf\u8db3\u591f\u597d\uff1a</p> <ul> <li>\u5b83\u662f\u5426\u7a33\u5b9a\u53ef\u9760</li> <li>\u5b83\u662f\u5426\u4e0d\u4f1a\u9891\u7e41\u6253\u65ad\u4f60\u7684\u6ce8\u610f\u529b</li> <li>\u5b83\u662f\u5426\u80fd\u591f\u652f\u6491\u4f60\u6301\u7eed\u4ea7\u51fa</li> </ul> <p>\u53ea\u8981\u7b54\u6848\u662f\u201c\u53ef\u4ee5\u201d\uff0c\u90a3\u5b83\u5927\u6982\u7387\u5c31\u5df2\u7ecf\u591f\u7528\u4e86\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_5","title":"\u600e\u6837\u51cf\u5c11\u5de5\u5177\u7656","text":"","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_6","title":"\u9650\u5236\u66f4\u6362\u9891\u7387","text":"<p>\u7ed9\u81ea\u5df1\u8bbe\u5b9a\u4e00\u4e2a\u5468\u671f\uff0c\u6bd4\u5982 1 \u4e2a\u6708\u6216 1 \u4e2a\u5b63\u5ea6\u5185\u4e0d\u6362\u6838\u5fc3\u5de5\u5177\u3002\u5148\u628a\u65f6\u95f4\u82b1\u5728\u4f7f\u7528\u4e0a\uff0c\u518d\u8bc4\u4f30\u662f\u5426\u771f\u7684\u9700\u8981\u8c03\u6574\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_7","title":"\u5148\u505a\u4e8b\uff0c\u518d\u4f18\u5316","text":"<p>\u6bcf\u6b21\u60f3\u6298\u817e\u5de5\u5177\u65f6\uff0c\u5148\u95ee\u81ea\u5df1\u4e00\u4e2a\u95ee\u9898\uff1a</p> <p>\u8fd9\u4e2a\u6539\u52a8\uff0c\u4f1a\u4e0d\u4f1a\u8ba9\u6211\u4eca\u5929\u66f4\u63a5\u8fd1\u7ed3\u679c\uff1f</p> <p>\u5982\u679c\u4e0d\u4f1a\uff0c\u90a3\u5c31\u5148\u8bb0\u4e0b\u6765\uff0c\u7b49\u4efb\u52a1\u7ed3\u675f\u540e\u518d\u5904\u7406\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_8","title":"\u5728\u4f7f\u7528\u4e2d\u5fd8\u8bb0\u5de5\u5177\u7684\u5b58\u5728","text":"<p>\u6700\u597d\u7684\u72b6\u6001\u4e0d\u662f\u201c\u6211\u62e5\u6709\u4e00\u4e2a\u5f88\u5f3a\u7684\u5de5\u5177\u7cfb\u7edf\u201d\uff0c\u800c\u662f\u201c\u6211\u5728\u505a\u4e8b\u65f6\u51e0\u4e4e\u611f\u89c9\u4e0d\u5230\u5de5\u5177\u7684\u5b58\u5728\u201d\u3002</p> <p>\u5f53\u4e00\u4e2a\u5de5\u5177\u771f\u6b63\u878d\u5165\u5de5\u4f5c\u6d41\uff0c\u5b83\u4f1a\u50cf\u952e\u76d8\u3001\u676f\u5b50\u3001\u6c7d\u8f66\u4e00\u6837\u81ea\u7136\uff1a\u4f60\u5728\u7528\u5b83\uff0c\u4f46\u4e0d\u4f1a\u4e0d\u65ad\u610f\u8bc6\u5230\u5b83\u3002</p>","tags":["\u81ea\u6211\u514b\u670d"]},{"location":"tool-obsession/#_9","title":"\u7ed3\u8bed","text":"<p>\u5de5\u5177\u672c\u6765\u662f\u4e3a\u4e86\u670d\u52a1\u4eba\uff0c\u800c\u4e0d\u662f\u8ba9\u4eba\u56f4\u7740\u5b83\u6253\u8f6c\u3002</p> <p>\u5982\u679c\u4e00\u4e2a\u5de5\u5177\u8ba9\u4f60\u8d8a\u6765\u8d8a\u50cf\u4e00\u4e2a\u7814\u7a76\u5de5\u5177\u7684\u4eba\uff0c\u800c\u4e0d\u662f\u4e00\u4e2a\u6b63\u5728\u63a8\u8fdb\u4e8b\u60c5\u7684\u4eba\uff0c\u90a3\u4e48\u95ee\u9898\u901a\u5e38\u4e0d\u5728\u5de5\u5177\u672c\u8eab\uff0c\u800c\u5728\u4f60\u5df2\u7ecf\u628a\u201c\u5de5\u5177\u201d\u9519\u5f53\u6210\u4e86\u201c\u5de5\u4f5c\u201d\u3002</p> <p>\u6700\u540e\u66f4\u65b0\uff1a2026\u5e743\u6708</p>","tags":["\u81ea\u6211\u514b\u670d"]}]}